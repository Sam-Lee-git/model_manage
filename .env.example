# ── Active LLM provider ───────────────────────────────────────────────────────
# "auto" = detect from env vars automatically (default, recommended).
# Override: claude | openai | gemini | qwen | minimax | deepseek
# MM_LLM_PROVIDER=auto

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
QWEN_API_KEY=sk-...
MINIMAX_API_KEY=...
DEEPSEEK_API_KEY=sk-...

# ── Model overrides (optional) ────────────────────────────────────────────────
# MM_CLAUDE_MODEL=claude-sonnet-4-6
# MM_OPENAI_MODEL=gpt-4o
# MM_GEMINI_MODEL=gemini-2.0-flash
# MM_QWEN_MODEL=qwen-max
# MM_MINIMAX_MODEL=abab6.5s-chat
# MM_DEEPSEEK_MODEL=deepseek-chat

# ── Base URL overrides (for proxy / self-hosted) ──────────────────────────────
# MM_OPENAI_BASE_URL=https://my-proxy.example.com/v1
# MM_GEMINI_BASE_URL=
# MM_QWEN_BASE_URL=
# MM_MINIMAX_BASE_URL=
# MM_DEEPSEEK_BASE_URL=

# ── Other settings ────────────────────────────────────────────────────────────
MM_LOG_LEVEL=INFO
MM_DATA_DIR=~/.model_manager
